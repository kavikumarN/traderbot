# Copy to .env and fill in real values. Never commit the real .env file.

# --- App ---
APP_NAME=traderbot-backend
ENVIRONMENT=local            # local | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console           # console | json

# --- API ---
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173"]

# --- Database ---
DATABASE_URL=postgresql+asyncpg://traderbot:traderbot@localhost:5432/traderbot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security / JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-every-environment
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Password policy ---
PASSWORD_MIN_LENGTH=10

# --- Binance ---
# Optional: public market data (tickers, candles, order book) needs no
# authentication. Only required once account/order endpoints are called
# (i.e. TRADING_MODE=live).
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_REST_BASE_URL=https://api.binance.com
BINANCE_WS_BASE_URL=wss://stream.binance.com:9443
BINANCE_RECV_WINDOW_MS=5000
BINANCE_REQUEST_WEIGHT_LIMIT=6000
BINANCE_REQUEST_WEIGHT_WINDOW_SECONDS=60.0
BINANCE_ORDER_LIMIT=100
BINANCE_ORDER_WINDOW_SECONDS=10.0
BINANCE_MAX_RETRIES=3
BINANCE_RETRY_BASE_DELAY_SECONDS=0.5

# --- Market data engine ---
# JSON-array syntax, not comma-separated — pydantic-settings tries to
# JSON-decode any list-typed env var (from a .env file or a real OS env
# var alike) before Settings' own comma-splitting validator ever gets a
# chance to run, so a bare "BTCUSDT,ETHUSDT" fails to parse.
MARKET_DATA_SYMBOLS=["BTCUSDT","ETHUSDT"]
MARKET_DATA_CANDLE_INTERVALS=["1m"]
MARKET_DATA_ORDER_BOOK_PERSIST_INTERVAL_SECONDS=1.0

# --- Trading engine ---
# "paper" runs every order through the in-memory simulator against real
# market prices — no order ever reaches Binance. Defaults to "paper" so a
# fresh deployment can never place a real order by accident.
TRADING_MODE=paper
PAPER_TRADING_STARTING_BALANCE_USDT=100000
PAPER_TRADING_COMMISSION_RATE=0.001
